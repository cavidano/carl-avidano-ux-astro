---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header/Header.astro';
import { getAllProjects, getProjectBySlug } from '../../lib/projects.js';
import CaseStudyOverview from '../../components/CaseStudyOverview.astro';
import Divider from '../../components/Divider.astro';
import FigureSideBySide from '../../components/FigureSideBySide.astro';
import FigureSingle from '../../components/FigureSingle.astro';
import IntroBlock from '../../components/IntroBlock.astro';
import LinkOpenNew from '../../components/LinkOpenNew.astro';
import ProjectLinkButton from '../../components/ProjectLinkButton.astro';
import TextBlock from '../../components/TextBlock.astro';
import ThemeWrapper from '../../components/ThemeWrapper.astro';

interface ProjectFrontmatter {
  title: string;
  description: string;
  tagline?: string;
  primaryColor: string;
  primaryTextColor: string;
  secondaryColor: string;
  secondaryTextColor: string;
}

interface Project {
  slug: string;
  marqueeImage: ImageMetadata;
  Content: any;
  frontmatter: ProjectFrontmatter;
}

export function getStaticPaths() {
  return (getAllProjects() as Project[]).map((project: Project) => ({
    params: {
      slug: project.slug
    }
  }));
}

const project = getProjectBySlug(Astro.params.slug) as Project | undefined;

if (!project) {
  return Astro.redirect('/404');
}

const { Content, frontmatter } = project;
const mdxComponents = {
  CaseStudyOverview,
  Divider,
  FigureSideBySide,
  FigureSingle,
  IntroBlock,
  LinkOpenNew,
  ProjectLinkButton,
  TextBlock,
  ThemeWrapper
};
const title = `${frontmatter.title} • Carl Avidano • UX Manager`;
const description = frontmatter.description;
const projectThemeStyles = `--primary: ${frontmatter.primaryColor}; --primary-text: ${frontmatter.primaryTextColor}; --secondary: ${frontmatter.secondaryColor}; --secondary-text: ${frontmatter.secondaryTextColor};`;
---
<Layout title={title} description={description}>
  <div class="theme-primary overflow-hidden" style={projectThemeStyles}>
    <div>
      <Header />

      <header class="marquee">
        <div class="container wide">
          <div class="grid grid--column-7--xl align-items-end--xl gap-5--xl margin-top-5">
            <div class="grid__colspan-3--xl">
              <div class="margin-y-5">
                <h1 class="banner-headline">{frontmatter.title}</h1>
                <p>{frontmatter.tagline || frontmatter.description}</p>
              </div>
            </div>

            <div class="grid__colspan-4--xl">
              <Image
                class="project-image"
                src={project.marqueeImage}
                alt=""
                loading="eager"
                fetchpriority="high"
              />
            </div>
          </div>
        </div>
      </header>
    </div>
  </div>

  <main id="skip-header-target" style={projectThemeStyles}>
    <article class="margin-y-5">
      <Content components={mdxComponents} />
    </article>
  </main>
</Layout>

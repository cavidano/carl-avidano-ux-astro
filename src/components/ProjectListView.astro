---
import { Image } from 'astro:assets';
import Button from './Button.astro';

interface ProjectListItem {
  slug: string;
  marqueeImage: ImageMetadata;
  frontmatter: {
    title: string;
    description: string;
    primaryColor: string;
    primaryTextColor: string;
    buttonLabel?: string;
  };
}

interface Props {
  projects?: ProjectListItem[];
}

const { projects = [] } = Astro.props as Props;
---
<div class="grid gap-3 margin-y-5">
  {projects.map((project: ProjectListItem, index: number) => (
    <section
      class="theme-primary container"
      aria-labelledby={`project-${project.slug}`}
      style={`--primary: ${project.frontmatter.primaryColor}; --primary-text: ${project.frontmatter.primaryTextColor};`}
    >
      <div class="grid grid--column-7--xl align-items-center--xl gap-5--xl">
        <div class="container--xl grid__colspan-4--xl order-2--xl margin-top-4">
          <Image
            class="project-image"
            src={project.marqueeImage}
            alt=""
            loading={index < 2 ? 'eager' : 'lazy'}
            fetchpriority={index === 0 ? 'high' : 'auto'}
          />
        </div>

        <div class="container--xl grid__colspan-3--xl margin-y-4">
          <h2 id={`project-${project.slug}`}>{project.frontmatter.title}</h2>
          <p>{project.frontmatter.description}</p>

          <Button
            href={`/portfolio/${project.slug}`}
            outline
            utilities="font-size-md"
            title={project.frontmatter.buttonLabel || 'View Project'}
          />
        </div>
      </div>
    </section>
  ))}
</div>

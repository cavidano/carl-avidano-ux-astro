---
import Footer from '../components/Footer.astro';
import defaultSocialImage from '../images/carl-avidano-16x9.jpg';
import '@natura11y/icons/dist/natura11y-icons.css';
import '../styles/global.scss';

const {
  title = 'Carl Avidano • UX Manager',
  description = 'Carl Avidano is a UX leader, researcher, and inclusive design advocate specializing in digital accessibility, design systems, and front-end development.',
  image = defaultSocialImage,
  imageAlt = 'Portrait of Carl Avidano',
  noindex = false
} = Astro.props;

const siteUrl = Astro.site ?? Astro.url;
const canonicalUrl = Astro.url.pathname === '/'
  ? siteUrl.origin
  : new URL(Astro.url.pathname, siteUrl).href;
const socialImagePath = typeof image === 'string' ? image : image.src;
const socialImageUrl = new URL(socialImagePath, siteUrl).href;
---

<!doctype html>

<html lang="en" class="theme-dark">
  
  <head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Carl Avidano" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inclusive+Sans:ital,wght@0,300..700;1,300..700&display=swap" />
    
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem('preferred-theme') || 'dark';
          document.documentElement.className = savedTheme === 'light' ? 'theme-canvas' : 'theme-dark';
        } catch {
          document.documentElement.className = 'theme-dark';
        }
      })();
    </script>
  </head>

  <body>
    
    <div class="skip-links">
      <a href="#skip-header-target">Jump to main content</a>
    </div>
    
    <slot />
       
    <Footer />
    
    <script is:inline>
      (() => {
        /**
         * @param {string} theme
         */
        const setTheme = (theme) => {
          document.documentElement.className = theme === 'light' ? 'theme-canvas' : 'theme-dark';
          localStorage.setItem('preferred-theme', theme);
        };

        document.querySelector('[data-theme-toggle]')?.addEventListener('click', () => {
          const nextTheme = document.documentElement.classList.contains('theme-canvas') ? 'dark' : 'light';
          setTheme(nextTheme);
        });

        document.querySelector('[data-back-to-top]')?.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: 'smooth'
          });
        });
      })();
    </script> 

  </body>

</html>
